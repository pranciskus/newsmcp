  "bin": {
    "newsmcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "news",
    "world-news",
    "ai",
    "llm",
    "claude",
    "chatgpt"
  ],
  "author": "pranciskus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pranciskus/news-mcp.git"
  },
  "homepage": "https://github.com/pranciskus/news-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
