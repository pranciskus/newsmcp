{
  "name": "@newsmcp/openclaw",
  "version": "1.0.7",
  "description": "OpenClaw plugin for real-time AI-clustered world news — topic and geographic filtering from newsmcp.io. Free, no API key.",
  "type": "module",
  "license": "MIT",
  "author": "pranciskus",
  "repository": {
    "type": "git",
    "url": "https://github.com/pranciskus/newsmcp.git",
    "directory": "packages/openclaw-plugin"
  },
  "homepage": "https://newsmcp.io",
  "keywords": [
    "openclaw-plugin",
    "news",
    "world-news",
    "ai-agents",
    "newsmcp",
    "openclaw"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "install": {
      "npmSpec": "@newsmcp/openclaw",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
